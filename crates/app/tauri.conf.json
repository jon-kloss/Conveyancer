{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MANIFOLD",
  "version": "0.1.0",
  "identifier": "dev.ficsit.planner",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../renderer dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --dir ../../renderer build",
    "frontendDist": "../../renderer/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MANIFOLD",
        "width": 1920,
        "height": 1080,
        "minWidth": 800,
        "minHeight": 500,
        "maximized": true,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
