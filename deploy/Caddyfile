# Caddy static server for the MANIFOLD web build (Web Phase 4a).
# The whole app runs client-side (wasm Session in a Web Worker over IndexedDB) —
# there is NO backend here, so this only serves the built `dist-web` bundle.
#
# Railway injects $PORT; Caddy binds it (default 8080 for local `docker run`).
# admin/auto_https are off because Railway terminates TLS at its edge and gives
# us a plain HTTP port to listen on.
{
	admin off
	auto_https off
}

:{$PORT:8080} {
	root * /srv
	encode zstd gzip

	# Correct MIME for the wasm module — a wrong type makes the browser refuse
	# streaming instantiation. Caddy's default map already sets application/wasm,
	# but pin it so the deploy never depends on the base image's mime table.
	@wasm path *.wasm
	header @wasm Content-Type application/wasm

	# Vite fingerprints every asset (content hash in the name), so they are
	# immutable — cache them hard. The entry document must NOT be cached long, so
	# a redeploy is picked up immediately — match BOTH the served root `/` and
	# `/index.html` (the app is served at `/`, which file_server resolves to
	# index.html without a rewrite, so a bare `/index.html` matcher would miss it
	# and a stale root could request purged asset names → 404 until hard refresh).
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	@html path / /index.html
	header @html Cache-Control "no-cache"

	# Public assets (icons, map tiles) are NOT fingerprinted, so no `immutable`:
	# a short shared max-age with revalidation keeps them cheap without letting
	# any bad response outlive the next reload.
	@public path /icons/* /map/*
	header @public Cache-Control "public, max-age=3600, stale-while-revalidate=86400"

	# Asset paths must 404 when missing — NEVER fall back to index.html. During
	# a redeploy hiccup the SPA fallback answered icon requests with 200 + HTML;
	# with no explicit cache policy the browser heuristically CACHED those
	# HTML-as-PNG bodies, and every game icon stayed "broken" until a hard
	# refresh (2026-07-19 live incident). Errors must stay errors: a 404 is
	# retried on the next load, a cached 200 is not.
	@asset path /assets/* /icons/* /map/*
	handle @asset {
		file_server
	}

	# Single-page app: unknown NAVIGATION paths fall back to the shell
	# (harmless here — the app has no client-side router yet — but correct if
	# one is added later).
	handle {
		try_files {path} /index.html
		file_server
	}
}
